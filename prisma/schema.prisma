//   Title: Prisma Schema - Model Lengkap ReWardrobe
//   Type: ai
//   Value: Claude (claude.ai/code)
//   Notes: Skema database lengkap termasuk model BarangDonasi, Permintaan, Pengiriman, LogPoin, Notifikasi, dan semua enum
//   Lines Range: 151
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int           @id @default(autoincrement())
  nama           String
  email          String        @unique
  password       String
  no_telpon      String?
  alamat_lengkap String?
  kota           String?
  foto_profil    String?
  role           RoleUser
  tipe           TipePenerima?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  barang_donasi  BarangDonasi[] @relation("BarangDonasi_donatur")
  barang_diverif BarangDonasi[] @relation("BarangDonasi_verifier")
  permintaan     Permintaan[]
  log_poin       LogPoin[]
  notifikasi     Notifikasi[]
  donasi_uang    DonasiUang[]   @relation("DonasiUang_donatur")
  donasi_uang_diverif DonasiUang[] @relation("DonasiUang_verifier")
  partisipasi_campaign PartisipasiCampaign[]

  @@map("users")
}

model BarangDonasi {
  id          Int          @id @default(autoincrement())
  judul       String?
  deskripsi   String
  kondisi_user String      @default("fair")
  kategori    String?
  berat_kg    Float?
  foto_url    String?
  label_ai    LabelAI?
  status      StatusBarang @default(menunggu_verifikasi)
  donatur_id  Int
  verified_by Int?
  verified_at DateTime?
  campaign_id Int?
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  donatur    User         @relation("BarangDonasi_donatur", fields: [donatur_id], references: [id])
  verifier   User?        @relation("BarangDonasi_verifier", fields: [verified_by], references: [id])
  campaign   Campaign?    @relation(fields: [campaign_id], references: [id])
  permintaan Permintaan[]
  pengiriman Pengiriman[]

  @@map("barang_donasi")
}

model Permintaan {
  id          Int              @id @default(autoincrement())
  barang_id   Int
  penerima_id Int
  pesan       String?
  status      StatusPermintaan @default(menunggu)
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt

  barang   BarangDonasi @relation(fields: [barang_id], references: [id])
  penerima User         @relation(fields: [penerima_id], references: [id])

  @@map("permintaan")
}

model Pengiriman {
  id         Int              @id @default(autoincrement())
  barang_id  Int
  tipe       TipePengiriman
  kurir      String?
  status     StatusPengiriman @default(disiapkan)
  resi       String?
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt

  barang BarangDonasi @relation(fields: [barang_id], references: [id])

  @@map("pengiriman")
}

model LogPoin {
  id         Int      @id @default(autoincrement())
  user_id    Int
  poin       Int
  keterangan String?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("log_poin")
}

model Notifikasi {
  id         Int      @id @default(autoincrement())
  user_id    Int
  judul      String
  pesan      String
  dibaca     Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("notifikasi")
}

enum RoleUser {
  admin
  donatur
  penerima
}

enum TipePenerima {
  panti
  komunitas
  pengrajin
}

enum StatusBarang {
  menunggu_verifikasi
  disetujui
  ditolak
  tersalurkan
}

enum LabelAI {
  layak_donasi
  perlu_perbaikan
  daur_ulang
}

enum TipePengiriman {
  donatur_ke_admin
  admin_ke_penerima
}

enum StatusPermintaan {
  menunggu
  diterima
  ditolak
}

enum StatusPengiriman {
  disiapkan
  dalam_pengiriman
  terkirim
}

model Campaign {
  id             Int                   @id @default(autoincrement())
  judul          String
  deskripsi      String
  target_dana    Float?                // Target dana (nominal Rupiah), null jika hanya pakaian
  terkumpul_dana Float                 @default(0)
  target_barang  Int?                  // Target jumlah pakaian, null jika hanya uang
  terkumpul_barang Int                @default(0)
  foto_url       String?
  status         String                @default("aktif") // "aktif" | "selesai"
  created_at     DateTime              @default(now())
  updated_at     DateTime              @updatedAt

  barang_donasi  BarangDonasi[]
  donasi_uang    DonasiUang[]
  partisipan     PartisipasiCampaign[]

  @@map("campaigns")
}

model PartisipasiCampaign {
  id          Int      @id @default(autoincrement())
  user_id     Int
  campaign_id Int
  created_at  DateTime @default(now())

  user     User     @relation(fields: [user_id], references: [id])
  campaign Campaign @relation(fields: [campaign_id], references: [id])

  @@unique([user_id, campaign_id])
  @@map("partisipasi_campaign")
}

model DonasiUang {
  id             Int          @id @default(autoincrement())
  nominal        Float
  bukti_transfer String
  catatan        String?
  status         StatusBarang @default(menunggu_verifikasi)
  donatur_id     Int
  campaign_id    Int?
  verified_by    Int?
  verified_at    DateTime?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  donatur  User      @relation("DonasiUang_donatur", fields: [donatur_id], references: [id])
  verifier User?     @relation("DonasiUang_verifier", fields: [verified_by], references: [id])
  campaign Campaign? @relation(fields: [campaign_id], references: [id])

  @@map("donasi_uang")
}
